-- Rarity colors
local RARITY_COLORS = {
    Common = 0x808080,
    Uncommon = 0x3BC84D,
    Rare = 0x3D82FF,
    Epic = 0xA03CE0,
    Legendary = 0xFFD700,
    Mythic = 0xDC2828,
    Super = 0xFF6B00,
    Secret = 0x000000,
}

-- Send embed
local function sendPetEmbed(pets, placeId, jobId, joinCmd)
    if #pets == 0 then
        print("[Debug] No pets to send in embed.")
        return
    end

    print("[Debug] Preparing embed with " .. #pets .. " pets.")

    -- Highest rarity
    local highestRarity = "Common"
    local rarityRank = { Common=1, Uncommon=2, Rare=3, Epic=4, Legendary=5, Mythic=6, Super=7, Secret=8 }
    for _, p in ipairs(pets) do
        local rank = rarityRank[p.Rarity] or 0
        if rank > (rarityRank[highestRarity] or 0) then
            highestRarity = p.Rarity
        end
    end
    local embedColor = RARITY_COLORS[highestRarity] or 0xFFFFFF

    -- Pet list
    local petList = ""
    for i, p in ipairs(pets) do
        local priceStr = (p.Price and p.Price > 0) and ("¢" .. tostring(p.Price)) or "Unknown"
        petList = petList .. string.format("**%d.** %s (%s) – %s\n", i, p.Name, p.Rarity, priceStr)
    end
    if #petList > 1000 then petList = petList:sub(1, 997) .. "..." end

    local description = "A valuable pet has been detected in a public server."
    if DISCORD_USER_ID ~= "" then
        description = "<@" .. DISCORD_USER_ID .. "> " .. description
    end

    local embed = {
        title = "🔎 Rare Pet Found!",
        description = description,
        color = embedColor,
        fields = {
            {
                name = "🐾 **Pet**",
                value = petList,
                inline = false
            },
            {
                name = "📋 **Join Command**",
                value = "```lua\n" .. joinCmd .. "\n```",
                inline = false
            },
            {
                name = "🆔 **Server ID**",
                value = "`" .. jobId .. "`",
                inline = true
            },
            {
                name = "🌐 **Place ID**",
                value = "`" .. tostring(placeId) .. "`",
                inline = true
            }
        },
        footer = {
            text = "Pet Finder • " .. os.date("%Y-%m-%d %H:%M:%S")
        },
        timestamp = os.date("!%Y-%m-%dT%H:%M:%S.000Z")
    }

    local payload = {
        username = "Pet Scanner",
        avatar_url = "https://i.imgur.com/9Xn4K0a.png",
        embeds = { embed }
    }

    print("[Debug] Sending webhook...")
    postWebhook(WEBHOOK_URL, payload)
end

-- Get wild pet container
local function getWildPetContainer()
    local map = workspace:FindFirstChild("Map")
    if map then
        local ref = map:FindFirstChild("WildPetRef")
        if ref and ref:IsA("Folder") then
            print("[Debug] Found WildPetRef.")
            return ref
        end
        local spawns = map:FindFirstChild("WildPetSpawns")
        if spawns and spawns:IsA("Folder") then
            print("[Debug] Found WildPetSpawns.")
            return spawns
        end
    end
    print("[Debug] No wild pet container found.")
    return nil
end

-- Scan pets, excluding ignored
local function scanFilteredPets()
    local container = getWildPetContainer()
    if not container then
        print("[Debug] Container is nil.")
        return {}
    end
    local pets = {}
    local total = 0
    for _, petPart in ipairs(container:GetChildren()) do
        if petPart:IsA("BasePart") then
            total = total + 1
            local name = petPart:GetAttribute("PetName") or "Unknown"
            local ownerId = petPart:GetAttribute("OwnerUserId") or 0
            if ownerId == 0 and not IGNORE_PETS[name] then
                local rarity = petPart:GetAttribute("Rarity") or "Common"
                local petType = petPart:GetAttribute("PetType") or "Normal"
                local price = petPart:GetAttribute("Price") or 0
                table.insert(pets, {Name = name, Rarity = rarity, Type = petType, Price = price})
            end
        end
    end
    print(string.format("[Debug] Scanned %d total pet parts, found %d non-ignored, unowned pets.", total, #pets))
    return pets
end

local function makeJoinCommand(placeId, jobId)
    return string.format('game:GetService("TeleportService"):TeleportToPlaceInstance(%d, "%s", game:GetService("Players").LocalPlayer)',
        placeId, jobId)
end

local function processServer()
    print(string.format("[Process] Waiting %d seconds for map to load...", CHECK_DELAY))
    wait(CHECK_DELAY)

    local pets = scanFilteredPets()

    if #pets == 0 then
        print("[-] No non-ignored wild pets found. Hopping.")
        return false
    end

    print(string.format("[Debug] Found %d non-ignored unowned wild pet(s):", #pets))
    for _, p in ipairs(pets) do
        print(string.format("  - %s (%s, %s) - ¢%d", p.Name, p.Rarity, p.Type, p.Price))
    end

    local placeId = game.PlaceId
    local jobId = game.JobId
    local joinCmd = makeJoinCommand(placeId, jobId)

    print("\n========== SERVER WITH VALID PETS ==========")
    print("Pets found (excluding ignored list):")
    for _, p in ipairs(pets) do
        print(string.format("  - %s (%s, %s) - ¢%d", p.Name, p.Rarity, p.Type, p.Price))
    end
    print("\n📋 JOIN COMMAND:")
    print(joinCmd)
    print("============================================\n")

    sendPetEmbed(pets, placeId, jobId, joinCmd)
    return true
end

local function startHopping()
    print("[Serverhopper] Started. Delay = " .. CHECK_DELAY .. "s. Ignoring defined pets. Hopping forever.")
    while true do
        processServer()
        print("[~] Hopping to next server...")
        TeleportService:Teleport(game.PlaceId)
        return
    end
end

