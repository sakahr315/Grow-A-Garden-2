local STOP_AFTER_FIRST_GOOD = false   -- <-- hop forever

-- Rarity -> Embed Color (decimal)
local RARITY_COLORS = {
    Common = 0x808080,
    Uncommon = 0x3BC84D,
    Rare = 0x3D82FF,
    Epic = 0xA03CE0,
    Legendary = 0xFFD700,
    Mythic = 0xDC2828,
    Super = 0xFF6B00,
    Secret = 0x000000,
}
