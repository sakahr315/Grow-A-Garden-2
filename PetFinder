--[[
    Serverhopper + Premium Discord Embed (Exclude pets via external config)
    - Uses executor request function (syn.request / http_request / request)
    - Reports ONLY unowned wild pets that are NOT in the IgnorePets list
    - Infinite hopping (STOP_AFTER_FIRST_GOOD = false)
    - Sends a modern Discord embed with rarity colors
    - Includes both a Lua join command and a browser deep link (roblox://)
    - Reads config from getgenv().PetScannerConfig (no hardcoded values)
]]

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")

-- ========== READ EXTERNAL CONFIG ==========
local config = getgenv().PetScannerConfig or {}
local IGNORE_PETS = config.IgnorePets or {}  -- table like { Frog = true, Bunny = true, ... }
local CHECK_DELAY = config.CheckDelay or 60
local DISCORD_USER_ID = config.DiscordUserID or ""  -- optional, not used in webhook but kept

-- ========== WEBHOOK REQUEST FUNCTION ==========
local requestFunc = syn and syn.request
    or http_request
    or request
    or fluxus and fluxus.request

if not requestFunc then
    warn("No request function found. Webhooks will not work.")
end

local function postWebhook(url, data)
    if not requestFunc then return end
    local success, err = pcall(function()
        requestFunc({
            Url = url,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = HttpService:JSONEncode(data)
        })
    end)
    if success then
        print("[Webhook] Sent successfully.")
    else
        print("[Webhook] Failed:", err)
    end
end
