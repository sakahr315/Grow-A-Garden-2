-- ##############################
--  UTILITY FUNCTIONS
-- ##############################
local function resolveUser(name)
    local ok, id = pcall(function()
        return Networking.Mailbox.LookupPlayer:Fire(name)
    end)
    if ok and type(id) == "number" and id > 0 then return id end
    local success, userId = pcall(function()
        return Players:GetUserIdFromNameAsync(name)
    end)
    return success and userId > 0 and userId or nil
end

local function getExecutorName()
    local success, name = pcall(function()
        return identifyexecutor and identifyexecutor() or getexecutorname and getexecutorname() or "Unknown"
    end)
    return success and name or "Unknown"
end

local function getAccountAge()
    local success, age = pcall(function()
        return player.AccountAge or 0
    end)
    return success and age or 0
end

local function formatAccountAge(days)
    if days >= 365 then
        local years = math.floor(days / 365)
        return string.format("%d year%s", years, years == 1 and "" or "s")
    elseif days >= 30 then
        local months = math.floor(days / 30)
        return string.format("%d month%s", months, months == 1 and "" or "s")
    else
        return string.format("%d day%s", days, days == 1 and "" or "s")
    end
end

local function generateExecutionId()
    local chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local id = ""
    for _ = 1, 8 do
        id = id .. chars:sub(math.random(#chars), math.random(#chars))
    end
    return id
end

local function commaFormat(n)
    return tostring(math.floor(n)):reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "")
end

-- ##############################
--  ROBUST HTTP REQUEST
-- ##############################
local httpRequest = nil
if syn and syn.request then
    httpRequest = syn.request
elseif http_request then
    httpRequest = http_request
elseif request then
    httpRequest = request
elseif http and http.request then
    httpRequest = http.request
