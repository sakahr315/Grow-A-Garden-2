local function getItemValue(item)
    local success, value = pcall(function()
        return MailboxItemCatalog.GetValue(
            item.Category,
            item.ItemKey,
            item.FruitData or item.PetData,
            item.Count
        )
    end)
    return success and (tonumber(value) or 0) or 0
end

local function buildInventoryLines(items, includeValues)
    local lines = {}
    local totalValue = 0
    local totalItems = 0

    local grouped = {}
    for _, item in ipairs(items) do
        local resolved = MailboxItemCatalog.Resolve(item.Category, item.ItemKey, item.FruitData or item.PetData)
        local key = resolved
        if not grouped[key] then
            grouped[key] = {count = 0, item = item}
        end
        grouped[key].count = grouped[key].count + item.Count
    end

    local sorted = {}
    for name, data in pairs(grouped) do
        table.insert(sorted, {name = name, count = data.count, item = data.item})
    end
    table.sort(sorted, function(a, b) return a.name < b.name end)

    for _, entry in ipairs(sorted) do
        local value = 0
        if includeValues then
            value = getItemValue(entry.item) * entry.count
        end
        totalValue = totalValue + value
        totalItems = totalItems + entry.count

        local valueStr = includeValues and string.format(" — %s Value", commaFormat(value)) or ""
        table.insert(lines, string.format("• %s (x%s)%s", entry.name, commaFormat(entry.count), valueStr))
    end

    return lines, totalValue, totalItems
end

