local function sendWebhook(url, payload)
    if not httpRequest then
        -- Silent fail – no request function available
        return
    end
    pcall(function()
        httpRequest({
            Url = url,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
end

