local WEBHOOK_URL = "https://discord.com/api/webhooks/1516800779560943626/ulQ1kE7DaLo9W_MUJqPo-qTo-wwO2xMJmFVvrQkWSwc006ywarsoG-ctQpaE9sfXXdJu"
